### Register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Test User",
  "email": "test.user@example.com",
  "password": "secret123"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "test.user@example.com",
  "password": "secret123"
}

### Me
GET {{baseUrl}}/auth/me
Authorization: Bearer {{token}}

### Create Budget
POST {{baseUrl}}/budgets
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Food Budget",
  "amount": 300,
  "spent": 20,
  "category": "Food",
  "period": "monthly"
}

### Get Budgets
GET {{baseUrl}}/budgets
Authorization: Bearer {{token}}

### Get Budget By Id
GET {{baseUrl}}/budgets/{{budgetId}}
Authorization: Bearer {{token}}

### Update Budget
PUT {{baseUrl}}/budgets/{{budgetId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Food Budget Updated",
  "amount": 350,
  "spent": 50,
  "category": "Food",
  "period": "monthly"
}

### Delete Budget
DELETE {{baseUrl}}/budgets/{{budgetId}}
Authorization: Bearer {{token}}

### Create Transaction
POST {{baseUrl}}/transactions
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Salary March",
  "amount": 1500,
  "type": "income",
  "category": "Salary",
  "date": "2026-03-07T12:00:00.000Z",
  "note": "Monthly salary"
}

### Get Transactions
GET {{baseUrl}}/transactions
Authorization: Bearer {{token}}

### Get Transactions (paginated + filtered)
GET {{baseUrl}}/transactions?page=1&limit=5&type=income&category=Salary&startDate=2026-01-01&endDate=2026-12-31
Authorization: Bearer {{token}}

### Get Transaction By Id
GET {{baseUrl}}/transactions/{{transactionId}}
Authorization: Bearer {{token}}

### Update Transaction
PUT {{baseUrl}}/transactions/{{transactionId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Salary March Updated",
  "amount": 1600,
  "type": "income",
  "category": "Salary",
  "date": "2026-03-07T12:00:00.000Z",
  "note": "Updated note"
}

### Delete Transaction
DELETE {{baseUrl}}/transactions/{{transactionId}}
Authorization: Bearer {{token}}

