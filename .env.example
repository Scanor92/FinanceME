MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
PORT=5000
JWT_SECRET=change_me_for_demo_or_production
JWT_EXPIRES_IN=30d
CORS_ALLOWED_ORIGINS=http://localhost:8081,exp://127.0.0.1:8081

# Password reset
PASSWORD_RESET_DEBUG=true
PASSWORD_RESET_URL_BASE=http://localhost:8081/reset-password

# SMTP (optional for real email delivery)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="FinanceME <no-reply@example.com>"
