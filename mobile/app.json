{
  "expo": {
    "name": "FinaceME Mobile",
    "slug": "finaceme-mobile",
    "version": "1.0.0",
    "scheme": "finaceme",
    "icon": "./assets/images/logo.png",
    "extra": {
      "apiBaseUrl": "https://financeme-9h46.onrender.com/api",
      "eas": {
        "projectId": "661cbe61-ade3-4ed9-9a4f-8995b05e84b0"
      }
    },
    "orientation": "portrait",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C1120"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.finaceme.mobile",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ],
    "owner": "chibou"
  }
}
